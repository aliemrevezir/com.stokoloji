{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": false,
    "noImplicitAny": false,
    "sourceMap": true,
    "declaration": false,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "incremental": true
  },
  "include": ["./", "./**/*.ts", "./**/*.json"],
  "exclude": [
    "node_modules/",
    "build/",
    "dist/",
    ".cache/",
    ".tmp/",
    "src/admin/",
    "**/*.test.ts",
    "src/plugins/**"
  ]
}
