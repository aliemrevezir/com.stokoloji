      "type": "string",
      "required": true
    },
    "ctaLabel": {
      "type": "string"
    },
    "ctaHref": {
      "type": "string"
    },
    "ikon": {
      "type": "enumeration",
      "enum": ["sheet", "etiket", "zil", "hediye", "bilgi", "yildiz", "yok"],
      "default": "sheet"
    },
    "aktif": {
      "type": "boolean",
      "default": false
    },
    "sira": {
      "type": "integer",
      "default": 0
    }
  }
