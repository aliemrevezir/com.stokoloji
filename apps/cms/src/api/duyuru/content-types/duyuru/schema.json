{
  "kind": "collectionType",
  "collectionName": "duyurular",
  "info": {
    "singularName": "duyuru",
    "pluralName": "duyurular",
    "displayName": "Duyuru Barı",
    "description": "En üstteki utility bar duyuruları; birden fazla saklanır, aktif olan (en düşük sira) gösterilir"
