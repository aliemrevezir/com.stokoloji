{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog Yazısı",
    "description": "Blog içeriği; ilgili tool'a bağlanabilir"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "baslik": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "baslik",
      "required": true
    },
    "icerik": {
      "type": "json"
    },
    "kapakGorseli": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.meta"
    },
    "kategori": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::kategori.kategori"
    },
    "iliskiliTool": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tool.tool"
    },
    "yazar": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::yazar.yazar"
    },
    "sss": {
      "type": "component",
      "repeatable": true,
      "component": "content.sss"
    },
    "yayinTarihi": {
      "type": "datetime"
    },
    "guncellemeTarihi": {
      "type": "datetime"
    }
  }
}
