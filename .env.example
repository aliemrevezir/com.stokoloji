# ----------------------------------------------------------------------------
# Stokoloji — ortam değişkenleri (örnek)
# Bu dosyayı `.env` olarak kopyalayın. docker-compose.yml zaten dev için makul
# varsayılanları taşır; .env sadece üzerine yazmak istediklerinizi içerir.
# Gerçek .env asla git'e girmez (.gitignore).
# ----------------------------------------------------------------------------

# --- PostgreSQL ---
DATABASE_CLIENT=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=stokoloji
DATABASE_USERNAME=stokoloji
DATABASE_PASSWORD=stokoloji
DATABASE_SSL=false

# --- Strapi (CMS) güvenlik anahtarları ---
# Üretimde MUTLAKA rastgele değerlerle değiştirin (örn: `openssl rand -base64 16`).
APP_KEYS=devKeyOne==,devKeyTwo==,devKeyThree==,devKeyFour==
API_TOKEN_SALT=devApiTokenSaltChangeMe==
ADMIN_JWT_SECRET=devAdminJwtSecretChangeMe==
TRANSFER_TOKEN_SALT=devTransferTokenSaltChangeMe==
JWT_SECRET=devJwtSecretChangeMe==
ENCRYPTION_KEY=devEncryptionKeyChangeMe16Byte==

# --- Servisler arası iletişim ---
# Next.js SSR/build içi (Docker internal network):
STRAPI_INTERNAL_URL=http://cms:1337
# Tarayıcı (public) URL:
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# Opsiyonel: doluysa api-client Authorization: Bearer gönderir. Boşsa public read kullanılır.
STRAPI_API_TOKEN=

# --- Analitik (boş bırakılırsa analytics sessizce devre dışı kalır) ---
# GA4 Measurement ID (Google Analytics > Yönetici > Veri akışı): G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=
# Microsoft Clarity Project ID (clarity.microsoft.com > Setup): 10 haneli alfanümerik
NEXT_PUBLIC_CLARITY_ID=

# --- Search Console doğrulaması ---
# Önerilen yöntem registrar'da DNS TXT kaydıdır (deploy beklemeden tamamlanır).
# Bu değişken HTML meta-tag yöntemi içindir: Search Console'un verdiği
# "content" değeri (google-site-verification token'ı). Doluysa <head>'e basılır.
GOOGLE_SITE_VERIFICATION=

# --- Web kanonik site URL'i (sitemap/SEO için) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Listmonk (newsletter / lead-magnet ESP) ---
# Kendi postgres'i; boş bırakılırsa dev default'ları kullanılır.
LISTMONK_DB_NAME=listmonk
LISTMONK_DB_USER=listmonk
LISTMONK_DB_PASSWORD=listmonk
# İlk süper admin (yalnız ilk kurulumda oluşturulur). Admin panel: localhost:9000
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=listmonkadmin

# --- Newsletter API (web → Listmonk; SUNUCU tarafı, NEXT_PUBLIC değil) ---
# Listmonk admin panelinden: Settings > Users > yeni API user + token üret.
# Boş bırakılırsa abonelik formu sessizce devre dışı kalır (graceful).
LISTMONK_API_URL=http://localhost:9000
LISTMONK_API_USER=
LISTMONK_API_TOKEN=
# Varsayılan abone listesi ID(leri). Birden çok: virgülle (ör. 1,2).
LISTMONK_LIST_ID=
