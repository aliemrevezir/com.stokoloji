# ----------------------------------------------------------------------------
# Stokoloji — PRODUCTION ortam değişkenleri (Coolify referansı)
# Bu değerler Coolify'ın Environment Variables panelinden girilir.
# docker-compose.prod.yml bunları bekler. Gerçek değerleri ASLA git'e koyma.
# ----------------------------------------------------------------------------

# --- PostgreSQL ---
DATABASE_NAME=stokoloji
DATABASE_USERNAME=stokoloji
# Güçlü bir parola üret: openssl rand -base64 24
DATABASE_PASSWORD=

# --- Strapi güvenlik anahtarları (her biri ayrı, rastgele) ---
# Üret: openssl rand -base64 16   (APP_KEYS için 4 adet virgülle)
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# --- Strapi API token (Strapi admin'den üretilir; web read için) ---
STRAPI_API_TOKEN=

# --- Public URL'ler ---
# Web kanonik adres:
NEXT_PUBLIC_SITE_URL=https://stokoloji.com
# Strapi'nin PUBLIC adresi (tarayıcı medya URL'leri buradan; Coolify'da cms'e
# ayrı subdomain ver, örn. cms.stokoloji.com):
NEXT_PUBLIC_STRAPI_URL=https://cms.stokoloji.com

# --- Analitik (build-time gömülür → Coolify'da BUILD VARIABLE olarak da gir) ---
NEXT_PUBLIC_GA4_ID=G-3TQF6XG6XX
NEXT_PUBLIC_CLARITY_ID=x6l7nkaqw5

# --- Search Console (DNS ile doğrulandıysa boş bırak) ---
GOOGLE_SITE_VERIFICATION=
