# Postiz — Coolify env panelinden girilecek degiskenler.
# Bu dosyayi git'e KOYMA disinda referans olarak kullan; gercek degerleri Coolify'a gir.

# Tarayicidan erisilecek tam URL (Coolify'da bu domaini postiz servisine ata, port 5000).
POSTIZ_MAIN_URL=https://postiz.stokoloji.com

# Uzun rastgele string. Uret:  openssl rand -hex 32
POSTIZ_JWT_SECRET=

# Postiz veritabani parolasi (uret: openssl rand -hex 16)
POSTIZ_DB_PASSWORD=

# Temporal veritabani parolasi (uret: openssl rand -hex 16)
TEMPORAL_DB_PASSWORD=

# Ilk admin kaydindan sonra 'true' yapip redeploy et (acik kaydi kapatir).
POSTIZ_DISABLE_REGISTRATION=false

# Public API saatlik create-post limiti (varsayilan 90).
POSTIZ_API_LIMIT=90

# === Sosyal saglayici OAuth app anahtarlari ===
# X (Twitter) developer app'ten. Bos ise X baglanamaz.
X_API_KEY=
X_API_SECRET=

# LinkedIn developer app'ten. Bos ise LinkedIn baglanamaz.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
